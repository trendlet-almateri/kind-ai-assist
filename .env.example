# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_PROJECT_ID=your_project_id

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── WhatsApp via Twilio (webhook: /api/webhooks/twilio) ───────────────────────
# Set the inbound webhook in Twilio Console → Messaging → Senders →
# WhatsApp senders → [sender] → Messaging Endpoint Configuration →
# "Webhook URL for incoming messages": https://<your-domain>/api/webhooks/twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Order-status notification mirror (called by Trendlet) ─────────────────────
# Shared bearer token. Trendlet POSTs to /api/notifications/order-status with
# this token so outbound order updates appear in the customer's inbox thread.
# Must match SUPPORT_INBOX_TOKEN in Trendlet. Generate: openssl rand -base64 32
NOTIFICATIONS_API_TOKEN=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
NODE_ENV=production
