# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_PROJECT_ID=your_project_id

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── WhatsApp via Meta Business API (webhook: /api/webhooks/whatsapp) ───────────
# Only needed if you wire WhatsApp through Meta directly.
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token

# ── WhatsApp via Twilio (webhook: /api/webhooks/twilio) ───────────────────────
# Only needed if you wire WhatsApp through Twilio. Set the inbound webhook in
# Twilio Console → Messaging → Senders → WhatsApp senders → [sender] →
# Messaging Endpoint Configuration → "Webhook URL for incoming messages":
#   https://<your-domain>/api/webhooks/twilio   (HTTP POST)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
NODE_ENV=production
